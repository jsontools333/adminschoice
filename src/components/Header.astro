---
const nav = [
  { label: 'Topics', href: '/topics/' },
  { label: 'DevOps', href: '/topics/devops/' },
  { label: 'Shell', href: '/topics/shell/' },
  { label: 'All posts', href: '/posts/' },
];
---
<header class="site-header">
  <div class="site-header__inner">
    <a class="wordmark" href="/" aria-label="Admin's Choice home">
      <img class="wordmark__logo" src="/logo.png" alt="Admin's Choice" width="205" height="58" />
    </a>
    <input type="checkbox" id="nav-toggle" class="nav-toggle" aria-label="Toggle menu" />
    <label for="nav-toggle" class="nav-burger" aria-hidden="true">
      <span></span><span></span><span></span>
    </label>
    <nav class="nav" aria-label="Primary">
      {nav.map((item) => <a href={item.href}>{item.label}</a>)}
    </nav>
  </div>
</header>
