---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostList from '../../components/PostList.astro';

const posts = (await getCollection('posts'))
  .sort((a, b) => new Date(b.data.pubDate) - new Date(a.data.pubDate));

// Group by year for scannable browsing
const byYear = {};
for (const p of posts) {
  const y = new Date(p.data.pubDate).getFullYear();
  (byYear[y] ??= []).push(p);
}
const years = Object.keys(byYear).sort((a, b) => b - a);
---
<BaseLayout
  title="All posts — Admin's Choice"
  description="Every Admin's Choice reference and guide, newest first."
>
  <main class="archive">
    <h1>All posts</h1>
    <p class="lede">{posts.length} references and guides, newest first. <a href="/topics/">Browse by topic →</a></p>
    {years.map((year) => (
      <section class="year">
        <h2>{year}</h2>
        <PostList posts={byYear[year]} showTopic={true} />
      </section>
    ))}
  </main>
</BaseLayout>

<style>
  .archive { max-width: 720px; margin: 0 auto; padding: 2.5rem 1.5rem; }
  .lede { font-size: 1.05rem; color: var(--text-secondary); margin-bottom: 1.5rem; }
  .lede a { color: var(--accent-ink); text-decoration: none; }
  .year { margin-bottom: 2rem; }
  .year h2 { font-size: 1.1rem; color: var(--text-tertiary); font-family: var(--font-mono); letter-spacing: 0.04em; }
</style>
