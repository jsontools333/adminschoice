---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import AdUnit from '../components/AdUnit.astro';
import { ADSENSE } from '../config/adsense';

const posts = await getCollection('posts');
const bySlug = Object.fromEntries(posts.map((p) => [p.slug, p]));

// Essential Reading — explicitly curated, hand-ordered. The big-number hubs
// and strongest references go here and stay pinned (the cyberciti pattern).
const essentialSlugs = [
  '30-linux-commands-every-sysadmin-should-know',
  '25-systemd-commands-every-linux-admin-should-master',
  'ai-prompts-for-sre-devops',
  'crontab-quick-reference',
  'crontab-examples',
  'linux-monitoring-commands',
  'systemctl-commands',
  'ssh-without-password',
];
const essential = essentialSlugs.map((s) => bySlug[s]).filter(Boolean);

// Featured cards = featured posts that aren't already in Essential Reading
const featured = posts.filter((p) => p.data.featured && !essentialSlugs.includes(p.slug));
const recent = posts.sort((a, b) => new Date(b.data.pubDate) - new Date(a.data.pubDate)).slice(0, 8);
---
<BaseLayout title="Admin's Choice" description="Linux, DevOps, and cloud guides with real-world examples — tested commands for Docker, Kubernetes, networking, and systemd. Trusted by sysadmins and SREs since 2001.">
  <main class="home">
    <section class="hero">
      <span class="pill">Trusted since 2001 · rebuilt for 2026</span>
      <h1>Linux, DevOps, and cloud guides with examples for sysadmins and SREs</h1>
      <p>Tested commands, real-world examples, and honest comparisons. No fluff, no AI-generated filler — just the guides your team's wiki should be.</p>
      <div class="hero__cta">
        <a class="btn btn--primary" href="/topics/">Browse references →</a>
        <a class="btn btn--ghost" href="/posts/">View all posts</a>
      </div>
      <div class="hero__chips">
        <span class="chip"><b>$</b> systemctl restart nginx</span>
        <span class="chip"><b>$</b> kubectl get pods</span>
        <span class="chip"><b>$</b> docker compose up -d</span>
      </div>
    </section>

    {essential.length > 0 && (
      <section class="essential">
        <div class="essential__head">
          <h2>Essential reading</h2>
          <span class="essential__note">Start here — our most useful references</span>
        </div>
        <ol class="essential__list">
          {essential.map((p) => (
            <li class="essential__item">
              <a href={`/${p.slug}/`}>
                <span class="essential__title">{p.data.title}</span>
                <span class="essential__topic">{p.data.topic}</span>
              </a>
            </li>
          ))}
        </ol>
      </section>
    )}

    {featured.length > 0 && (
      <section>
        <h2>More popular references</h2>
        <div class="grid">
          {featured.map((p) => (
            <a class="card" href={`/${p.slug}/`}>
              <div class="card__topic">{p.data.topic}</div>
              <div class="card__title">{p.data.title}</div>
              <div class="card__desc">{p.data.description}</div>
            </a>
          ))}
        </div>
      </section>
    )}

    <section>
      <h2>Latest</h2>
      <ul class="list">
        {recent.map((p) => (
          <li><a href={`/${p.slug}/`}>{p.data.title}</a> <span class="list__topic">{p.data.topic}</span></li>
        ))}
      </ul>
      <p class="more"><a href="/posts/">See all {posts.length} posts →</a> · <a href="/topics/">Browse by topic</a></p>
    </section>

    <AdUnit slot={ADSENSE.slots.homeInline} />
  </main>
</BaseLayout>

<style>
  .home { max-width: 880px; margin: 0 auto; padding: 2.5rem 1.5rem; }
  .hero { text-align: center; margin: 1rem 0 2.5rem; }
  .pill { display: inline-block; padding: 5px 13px; background: var(--accent-wash); color: var(--accent-ink); font-size: 11.5px; font-weight: 500; font-family: var(--font-mono); letter-spacing: 0.04em; border-radius: 999px; margin-bottom: 20px; }
  .hero h1 { font-size: 2.6rem; line-height: 1.12; letter-spacing: -0.025em; color: var(--navy); max-width: 640px; margin: 0 auto 14px; }
  .hero p { font-size: 1.18rem; color: var(--text-secondary); max-width: 560px; line-height: 1.6; margin: 0 auto 24px; }
  .hero__cta { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; margin-bottom: 28px; }
  .btn { font-size: 14px; font-weight: 600; padding: 11px 22px; border-radius: 8px; display: inline-flex; align-items: center; gap: 7px; text-decoration: none; transition: transform .12s ease, background .15s ease, border-color .15s ease; }
  .btn:hover { transform: translateY(-1px); }
  .btn--primary { background: var(--red); color: #fff; }
  .btn--primary:hover { background: var(--red-deep); }
  .btn--ghost { background: var(--bg); color: var(--navy); border: 1px solid var(--border); }
  .btn--ghost:hover { border-color: var(--navy); }
  .hero__chips { display: flex; gap: 8px; justify-content: center; flex-wrap: wrap; }
  .chip { font-family: var(--font-mono); font-size: 12px; color: var(--navy-soft); background: var(--bg-secondary); border: 1px solid var(--border); padding: 6px 12px; border-radius: 7px; }
  .chip b { color: var(--accent-ink); font-weight: 700; }

  /* Essential Reading — pinned, numbered, the cyberciti-style flagship block */
  .essential {
    border: 0.5px solid var(--border);
    border-radius: 10px;
    padding: 22px 24px 14px;
    margin-bottom: 2.5rem;
    background: linear-gradient(180deg, var(--accent-wash), transparent 60%);
  }
  .essential__head { display: flex; align-items: baseline; justify-content: space-between; flex-wrap: wrap; gap: 8px; margin-bottom: 14px; }
  .essential__head h2 { margin: 0; font-size: 1.4rem; color: var(--navy); }
  .essential__note { font-size: 0.85rem; color: var(--text-secondary); }
  .essential__list {
    list-style: none;
    counter-reset: ess;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2px 24px;
  }
  .essential__item { counter-increment: ess; border-bottom: 0.5px solid var(--border); }
  .essential__item a {
    display: flex;
    align-items: baseline;
    gap: 10px;
    padding: 11px 2px;
    text-decoration: none;
    color: inherit;
  }
  .essential__item a::before {
    content: counter(ess);
    font-family: var(--font-mono);
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--accent);
    min-width: 18px;
  }
  .essential__item a:hover .essential__title { color: var(--accent-ink); }
  .essential__title { font-size: 0.98rem; font-weight: 500; line-height: 1.35; flex: 1; }
  .essential__topic { font-family: var(--font-mono); font-size: 0.62rem; text-transform: uppercase; letter-spacing: 0.04em; color: var(--text-tertiary); flex-shrink: 0; }
  @media (max-width: 600px) {
    .essential__list { grid-template-columns: 1fr; }
    .essential__topic { display: none; }
    .home { padding: 1.75rem 1.25rem; }
    .hero h1 { font-size: 1.95rem; }
    .hero p { font-size: 1.05rem; }
    .hero__chips .chip { font-size: 11px; }
  }

  .grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 10px; }
  .card { border: 0.5px solid var(--border); border-radius: var(--radius); padding: 16px; text-decoration: none; color: inherit; }
  .card:hover { border-color: var(--border-strong); }
  .card__topic { font-family: var(--font-mono); font-size: 11px; color: var(--accent-ink); text-transform: uppercase; letter-spacing: 0.04em; margin-bottom: 6px; }
  .card__title { font-size: 16px; font-weight: 600; margin-bottom: 5px; }
  .card__desc { font-size: 13.5px; color: var(--text-secondary); line-height: 1.5; }
  .list { list-style: none; padding: 0; }
  .list li { padding: 10px 0; border-bottom: 0.5px solid var(--border); font-size: 1.02rem; }
  .more { margin-top: 1.5rem; font-size: 1rem; }
  .more a { color: var(--accent-ink); text-decoration: none; }
  .list__topic { font-family: var(--font-mono); font-size: 11px; color: var(--text-tertiary); text-transform: uppercase; }
</style>
